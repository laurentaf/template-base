# ============================================================
# ENVIRONMENT VARIABLES REFERENCE
# Copy this file to .env and uncomment/configure as needed.
# ============================================================

# --- Project ---
# PROJECT_NAME=ai-data-project
# EXECUTION_TIER=development
# SERVICE_MODE=full

# --- Redis ---
# REDIS_URL=redis://localhost:6379

# --- Database ---
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/dbname

# --- Observability (Phoenix/Arize) ---
# PHOENIX_URL=http://localhost:6006

# --- NVIDIA NIM ---
# NVIDIA_API_KEY=nvapi-...
# NIM_BRIDGE_URL=http://localhost:8081/v1/chat/completions

# --- OpenRouter (fallback LLM) ---
# OPENROUTER_API_KEY=sk-or-...

# --- Tavily (web search for confidence research) ---
# TAVILY_API_KEY=tvly-...

# --- GitHub ---
# GITHUB_TOKEN=ghp_...

# --- OpenCode ---
# OPENCODE_API_KEY=...

# --- MinIO ---
# MINIO_URL=http://localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin

# --- Qdrant ---
# QDRANT_URL=http://localhost:6333

# --- MCP Servers ---
# MCP_POSTGRES_URL=...
# MCP_QDRANT_URL=...
# MCP_GITHUB_URL=...

# --- Agent Auto-Git/Doc ---
# AUTO_GIT=true
# AUTO_DOC=true

# --- Confidence Thresholds ---
# CONFIDENCE_THRESHOLD_CRITICAL=0.98
# CONFIDENCE_THRESHOLD_IMPORTANT=0.95
# CONFIDENCE_THRESHOLD_STANDARD=0.90
# CONFIDENCE_THRESHOLD_ADVISORY=0.80
# MAX_CONFIDENCE_RESEARCH_ROUNDS=3

# --- Self-Evolve ---
# EVOLVE_ENABLED=true
# LTADE_TEMPLATE_PATH=
# EVOLVE_AUTO_APPLY=false
# EVOLVE_MIN_CONFIDENCE=0.7
# LEARNING_EMIT_ENABLED=true
# EVOLVE_DAEMON_INTERVAL=300
# EVOLVE_DAEMON_AUTO_ANALYZE=true
# EVOLVE_DAEMON_AUTO_APPLY=false
