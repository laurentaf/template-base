# ============================================================
# ENVIRONMENT VARIABLES REFERENCE
# Set these at the OS level (System/User environment variables)
# or copy this file to .env and uncomment lines below.
# ============================================================

# --- Prefect ---
# PREFECT_API_URL=http://localhost:4200/api

# --- Database ---
# DATABASE_URL=postgresql+psycopg://prefect:password@localhost:5433/prefect

# --- Observability ---
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# --- NVIDIA NIM ---
# NVIDIA_API_KEY=nvapi-...
# NIM_BRIDGE_URL=http://localhost:8081/v1/chat/completions

# --- GitHub ---
# GITHUB_TOKEN=ghp_...

# --- MinIO ---
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
